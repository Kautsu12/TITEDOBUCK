---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { SITE, SOCIAL, AFFILIATE_DISCLOSURE } from '../config';

// Último post do blog (ignora rascunhos, ordena por data desc).
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latest = posts[0];

// Produtos em destaque para a vitrine (até 3).
const produtos = (await getCollection('produtos'))
  .sort((a, b) => a.data.order - b.data.order)
  .filter((p) => p.data.featured)
  .slice(0, 3);

const latestDate = latest?.data.pubDate.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout>
  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden border-b border-winter-600/60">
    <div
      class="absolute inset-0 bg-gradient-to-br from-winter-900 via-winter-800 to-winter-900"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-6xl px-4 py-24 text-center">
      <p class="mb-4 font-display text-sm uppercase tracking-[0.3em] text-star">
        ★ Soldado Invernal · Capitão América
      </p>
      <h1 class="mx-auto max-w-3xl font-display text-4xl font-bold uppercase leading-tight text-white sm:text-6xl">
        {SITE.tagline}
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-steel">{SITE.description}</p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href="/blog"
           class="rounded-lg bg-star px-6 py-3 font-semibold text-white transition hover:bg-red-700">
          Ler o blog
        </a>
        <a href="/loja"
           class="rounded-lg border border-winter-600 px-6 py-3 font-semibold text-white transition hover:border-star">
          Ver a loja
        </a>
      </div>
    </div>
  </section>

  <!-- ===== DESTAQUE DO ÚLTIMO POST ===== -->
  {latest && (
    <section class="mx-auto max-w-6xl px-4 py-20">
      <div class="mb-8 flex items-end justify-between">
        <h2 class="font-display text-2xl font-bold uppercase tracking-wide text-white">Último post</h2>
        <a href="/blog" class="text-sm text-steel transition hover:text-white">Ver tudo →</a>
      </div>

      <a href={`/blog/${latest.slug}`}
         class="group grid gap-6 overflow-hidden rounded-2xl border border-winter-600/60 bg-winter-800 md:grid-cols-2">
        <div class="aspect-video overflow-hidden bg-winter-700 md:aspect-auto">
          {latest.data.cover ? (
            <img src={latest.data.cover} alt={latest.data.title} loading="lazy"
                 class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
          ) : (
            <div class="flex h-full min-h-56 items-center justify-center text-6xl text-winter-600">★</div>
          )}
        </div>
        <div class="flex flex-col justify-center p-8">
          <div class="flex items-center gap-3 text-xs uppercase tracking-wide text-accent">
            <span>{latest.data.category}</span>
            <span class="text-steel/50">{latestDate}</span>
          </div>
          <h3 class="mt-3 font-display text-2xl font-bold text-white group-hover:text-star">
            {latest.data.title}
          </h3>
          <p class="mt-3 text-steel">{latest.data.description}</p>
          <span class="mt-5 text-sm font-semibold text-star">Ler artigo completo →</span>
        </div>
      </a>
    </section>
  )}

  <!-- ===== VITRINE DE PRODUTOS ===== -->
  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="mb-2 flex items-end justify-between">
      <h2 class="font-display text-2xl font-bold uppercase tracking-wide text-white">Loja do fã</h2>
      <a href="/loja" class="text-sm text-steel transition hover:text-white">Ver tudo →</a>
    </div>
    <p class="mb-8 max-w-2xl text-sm text-steel/70">{AFFILIATE_DISCLOSURE}</p>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {produtos.map((p) => (
        <ProductCard
          title={p.data.title}
          description={p.data.description}
          image={p.data.image}
          price={p.data.price}
          affiliateUrl={p.data.affiliateUrl}
          store={p.data.store}
          type={p.data.type}
        />
      ))}
    </div>
  </section>

  <!-- ===== CTA SOCIAL ===== -->
  <section class="mx-auto max-w-6xl px-4 pb-8">
    <div class="rounded-2xl border border-winter-600/60 bg-gradient-to-r from-winter-800 to-winter-700 p-10 text-center">
      <h2 class="font-display text-2xl font-bold uppercase text-white">Vem pro nosso quartel-general</h2>
      <p class="mx-auto mt-3 max-w-xl text-steel">
        Teorias diárias, edits e bastidores. Me siga nas redes para não perder nada.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <a href={SOCIAL.tiktok} target="_blank" rel="noopener"
           class="rounded-lg bg-star px-6 py-3 font-semibold text-white transition hover:bg-red-700">
          Seguir no TikTok
        </a>
        <a href={SOCIAL.twitter} target="_blank" rel="noopener"
           class="rounded-lg border border-winter-600 px-6 py-3 font-semibold text-white transition hover:border-star">
          Seguir no X
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

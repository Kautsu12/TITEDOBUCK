---
import BaseLayout from '../layouts/BaseLayout.astro';
import FanficLinks from '../components/FanficLinks.astro';
import hqs from '../data/hqs.json';
import livros from '../data/livros.json';

type Item = { title: string; description?: string; image?: string; url: string; store?: string };
const hqsList = hqs as Item[];
const livrosList = livros as Item[];

const curiosidades = [
  'O nome completo dele é James Buchanan "Bucky" Barnes.',
  'O codinome "Soldado Invernal" vem do programa soviético que o transformou em assassino.',
  'Nas HQs, Bucky chegou a assumir o manto de Capitão América após a "morte" de Steve Rogers.',
  'O braço biônico ganhou uma versão de vibranium, presente do Wakanda.',
  'Sebastian Stan interpreta o Bucky no cinema desde 2011, em "O Primeiro Vingador".',
  'As palavras de ativação em russo começam com "Anseio, Enferrujado, Dezessete...".',
];
---

<BaseLayout
  title="Descobertas"
  description="HQs e livros sobre o Bucky encontrados automaticamente, busca, curiosidades e fanfics."
>
  <section class="mx-auto max-w-6xl px-4 py-16">
    <h1 class="font-display text-3xl font-bold uppercase tracking-wide text-white">Descobertas</h1>
    <p class="mt-3 max-w-2xl text-steel">
      HQs e livros sobre o Soldado Invernal, atualizados sozinhos toda semana. Pesquise,
      explore curiosidades e encontre fanfics.
    </p>

    <!-- Busca -->
    <div class="mt-8 max-w-md">
      <input
        id="disc-search"
        type="search"
        placeholder="Pesquisar HQs e livros…"
        class="w-full rounded-lg border border-winter-600 bg-winter-800 px-4 py-3 text-white placeholder:text-steel/60 focus:border-star focus:outline-none"
        autocomplete="off"
      />
    </div>

    <!-- HQs -->
    <div class="mt-12">
      <h2 class="mb-6 font-display text-2xl font-bold uppercase tracking-wide text-white">HQs</h2>
      {hqsList.length === 0 ? (
        <p class="rounded-lg border border-winter-600/60 bg-winter-800 p-4 text-sm text-steel/80">
          As HQs aparecerão aqui assim que a busca automática rodar.
        </p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {hqsList.map((item) => (
            <a href={item.url} target="_blank" rel="sponsored nofollow noopener"
               class="disc-card group flex flex-col overflow-hidden rounded-xl border border-winter-600/60 bg-winter-800 transition hover:-translate-y-1 hover:border-star/70"
               data-title={item.title.toLowerCase()}>
              <div class="aspect-[2/3] overflow-hidden bg-gradient-to-br from-winter-700 to-winter-900">
                {item.image ? (
                  <img src={item.image} alt={item.title} loading="lazy"
                       class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
                ) : (
                  <div class="flex h-full w-full items-center justify-center">
                    <span class="font-display text-6xl text-star/25">★</span>
                  </div>
                )}
              </div>
              <div class="flex flex-1 flex-col p-4">
                <h3 class="font-display text-sm font-semibold leading-snug text-white">{item.title}</h3>
                <span class="mt-3 text-xs font-semibold text-star">Ver na {item.store} →</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Livros -->
    <div class="mt-14">
      <h2 class="mb-6 font-display text-2xl font-bold uppercase tracking-wide text-white">Livros</h2>
      {livrosList.length === 0 ? (
        <p class="rounded-lg border border-winter-600/60 bg-winter-800 p-4 text-sm text-steel/80">
          Os livros aparecerão aqui assim que a busca automática rodar.
        </p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {livrosList.map((item) => (
            <a href={item.url} target="_blank" rel="sponsored nofollow noopener"
               class="disc-card group flex flex-col overflow-hidden rounded-xl border border-winter-600/60 bg-winter-800 transition hover:-translate-y-1 hover:border-star/70"
               data-title={item.title.toLowerCase()}>
              <div class="aspect-[2/3] overflow-hidden bg-gradient-to-br from-winter-700 to-winter-900">
                {item.image ? (
                  <img src={item.image} alt={item.title} loading="lazy"
                       class="h-full w-full object-contain transition duration-500 group-hover:scale-105" />
                ) : (
                  <div class="flex h-full w-full items-center justify-center">
                    <span class="font-display text-6xl text-accent/25">★</span>
                  </div>
                )}
              </div>
              <div class="flex flex-1 flex-col p-4">
                <h3 class="font-display text-sm font-semibold leading-snug text-white">{item.title}</h3>
                <span class="mt-3 text-xs font-semibold text-star">Ver na {item.store} →</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Curiosidades -->
    <div class="mt-16">
      <h2 class="mb-6 font-display text-2xl font-bold uppercase tracking-wide text-white">Curiosidades</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {curiosidades.map((fato, i) => (
          <div class="flex gap-4 rounded-xl border border-winter-600/60 bg-winter-800 p-5">
            <span class="font-display text-2xl font-bold text-star">{String(i + 1).padStart(2, '0')}</span>
            <p class="text-sm leading-relaxed text-steel">{fato}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Fanfics -->
    <div class="mt-16">
      <h2 class="mb-2 font-display text-2xl font-bold uppercase tracking-wide text-white">Histórias não oficiais (fanfics)</h2>
      <p class="mb-6 max-w-2xl text-sm text-steel/80">
        Atalhos que abrem buscas prontas do Bucky nas principais plataformas.
      </p>
      <FanficLinks />
    </div>
  </section>

  <script is:inline>
    document.addEventListener('input', (e) => {
      const el = e.target;
      if (!el || el.id !== 'disc-search') return;
      const q = el.value.toLowerCase().trim();
      document.querySelectorAll('.disc-card').forEach((card) => {
        const t = card.getAttribute('data-title') || '';
        card.style.display = t.includes(q) ? '' : 'none';
      });
    });
  </script>
</BaseLayout>

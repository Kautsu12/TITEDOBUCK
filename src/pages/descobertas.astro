---
import BaseLayout from '../layouts/BaseLayout.astro';
import FanficLinks from '../components/FanficLinks.astro';
import hqs from '../data/hqs.json';
import livros from '../data/livros.json';

type Item = { title: string; description?: string; image?: string; url: string; store?: string };
const hqsList = hqs as Item[];
const livrosList = livros as Item[];
---

<BaseLayout
  title="Descobertas"
  description="HQs e livros sobre o Bucky encontrados automaticamente, além de buscas de fanfics."
>
  <section class="mx-auto max-w-6xl px-4 py-16">
    <h1 class="font-display text-3xl font-bold uppercase tracking-wide text-white">Descobertas</h1>
    <p class="mt-3 max-w-2xl text-steel">
      Esta página se atualiza sozinha: HQs e livros sobre o Soldado Invernal buscados
      automaticamente, mais atalhos para encontrar fanfics.
    </p>

    <!-- HQs automáticas -->
    <div class="mt-14">
      <h2 class="mb-6 font-display text-2xl font-bold uppercase tracking-wide text-white">HQs</h2>
      {hqsList.length === 0 ? (
        <p class="rounded-lg border border-winter-600/60 bg-winter-800 p-4 text-sm text-steel/80">
          As HQs aparecerão aqui assim que a busca automática rodar (requer as chaves da Marvel configuradas).
        </p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {hqsList.map((item) => (
            <a href={item.url} target="_blank" rel="sponsored nofollow noopener"
               class="group flex flex-col overflow-hidden rounded-xl border border-winter-600/60 bg-winter-800 transition hover:-translate-y-1 hover:border-star/70">
              {item.image && (
                <div class="aspect-[2/3] overflow-hidden bg-winter-700">
                  <img src={item.image} alt={item.title} loading="lazy"
                       class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
                </div>
              )}
              <div class="flex flex-1 flex-col p-4">
                <h3 class="font-display text-sm font-semibold leading-snug text-white">{item.title}</h3>
                <span class="mt-3 text-xs font-semibold text-star">Ver na {item.store} →</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Livros automáticos -->
    <div class="mt-14">
      <h2 class="mb-6 font-display text-2xl font-bold uppercase tracking-wide text-white">Livros</h2>
      {livrosList.length === 0 ? (
        <p class="rounded-lg border border-winter-600/60 bg-winter-800 p-4 text-sm text-steel/80">
          Os livros aparecerão aqui assim que a busca automática rodar (Google Books).
        </p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {livrosList.map((item) => (
            <a href={item.url} target="_blank" rel="sponsored nofollow noopener"
               class="group flex flex-col overflow-hidden rounded-xl border border-winter-600/60 bg-winter-800 transition hover:-translate-y-1 hover:border-star/70">
              {item.image && (
                <div class="aspect-[2/3] overflow-hidden bg-winter-700">
                  <img src={item.image} alt={item.title} loading="lazy"
                       class="h-full w-full object-contain transition duration-500 group-hover:scale-105" />
                </div>
              )}
              <div class="flex flex-1 flex-col p-4">
                <h3 class="font-display text-sm font-semibold leading-snug text-white">{item.title}</h3>
                <span class="mt-3 text-xs font-semibold text-star">Ver na {item.store} →</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Fanfics -->
    <div class="mt-14">
      <h2 class="mb-2 font-display text-2xl font-bold uppercase tracking-wide text-white">Histórias não oficiais (fanfics)</h2>
      <p class="mb-6 max-w-2xl text-sm text-steel/80">
        Não dá para importar fanfics automaticamente, mas estes atalhos abrem buscas
        prontas do Bucky nas principais plataformas.
      </p>
      <FanficLinks />
    </div>
  </section>
</BaseLayout>

---
import { SITE, SOCIAL, AFFILIATE_DISCLOSURE } from '../config';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-winter-600/60 bg-winter-800">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="flex flex-col items-start justify-between gap-8 md:flex-row">
      <div class="max-w-sm">
        <p class="font-display text-lg font-bold uppercase tracking-widest text-white">
          <span class="text-star">★</span> {SITE.title}
        </p>
        <p class="mt-3 text-sm text-steel">{SITE.tagline}.</p>
      </div>

      <div>
        <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-steel">Me siga</p>
        <div class="flex gap-3">
          <a href={SOCIAL.tiktok} target="_blank" rel="noopener"
             class="rounded-md bg-winter-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-star">
            TikTok
          </a>
          <a href={SOCIAL.twitter} target="_blank" rel="noopener"
             class="rounded-md bg-winter-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-star">
            X (Twitter)
          </a>
        </div>
      </div>
    </div>

    <p class="mt-10 text-xs leading-relaxed text-steel/70">{AFFILIATE_DISCLOSURE}</p>

    <p class="mt-4 text-xs text-steel/60">
      © {year} {SITE.title}. Site de fã, sem vínculo oficial com a Marvel ou The Walt Disney Company.
      Todas as marcas pertencem aos seus respectivos donos.
    </p>
  </div>
</footer>

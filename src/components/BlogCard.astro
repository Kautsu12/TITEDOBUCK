---
interface Props {
  title: string;
  description: string;
  href: string;
  pubDate: Date;
  category?: string;
  cover?: string;
}

const { title, description, href, pubDate, category = 'teoria', cover } = Astro.props;

const dateStr = pubDate.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<a
  href={href}
  class="group flex flex-col overflow-hidden rounded-xl border border-winter-600/60 bg-winter-800 transition hover:-translate-y-1 hover:border-star/70"
>
  {cover && (
    <div class="aspect-video overflow-hidden bg-winter-700">
      <img src={cover} alt={title} loading="lazy"
           class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
    </div>
  )}
  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-center gap-3 text-xs uppercase tracking-wide text-accent">
      <span>{category}</span>
      <span class="text-steel/50">{dateStr}</span>
    </div>
    <h3 class="mt-2 font-display text-lg font-semibold text-white group-hover:text-star">{title}</h3>
    <p class="mt-2 text-sm text-steel">{description}</p>
  </div>
</a>

---
// Botões que abrem buscas prontas de fanfics do Bucky (não importamos os textos —
// AO3/Wattpad/Spirit não permitem coleta automática; aqui levamos o leitor à fonte).
const buscas = [
  {
    nome: 'Spirit Fanfics',
    desc: 'Plataforma brasileira gigante de fanfics.',
    url: 'https://www.spiritfanfiction.com/busca?q=bucky+barnes',
  },
  {
    nome: 'Wattpad',
    desc: 'Histórias do Bucky por autores do mundo todo.',
    url: 'https://www.wattpad.com/search/bucky%20barnes',
  },
  {
    nome: 'Archive of Our Own (AO3)',
    desc: 'O maior acervo de fanfics em inglês.',
    url: 'https://archiveofourown.org/tags/Bucky%20Barnes/works',
  },
];
---

<div class="grid gap-4 sm:grid-cols-3">
  {buscas.map((b) => (
    <a
      href={b.url}
      target="_blank"
      rel="noopener"
      class="group flex flex-col rounded-xl border border-winter-600/60 bg-winter-800 p-5 transition hover:-translate-y-1 hover:border-star/70"
    >
      <span class="font-display text-lg font-semibold text-white group-hover:text-star">{b.nome}</span>
      <span class="mt-2 flex-1 text-sm text-steel">{b.desc}</span>
      <span class="mt-4 text-sm font-semibold text-star">Buscar fanfics →</span>
    </a>
  ))}
</div>

---
import { SITE, SOCIAL } from '../config';

const links = [
  { href: '/', label: 'Início' },
  { href: '/blog', label: 'Blog' },
  { href: '/loja', label: 'Loja' },
  { href: '/sobre', label: 'Sobre' },
];
---

<header class="sticky top-0 z-50 border-b border-winter-600/60 bg-winter-900/80 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
    <a href="/" class="flex items-center gap-2 font-display text-xl font-bold uppercase tracking-widest text-white">
      <span class="text-star">★</span>{SITE.title}
    </a>

    <div class="hidden items-center gap-6 md:flex">
      {links.map((l) => (
        <a href={l.href} class="text-sm font-medium text-steel transition hover:text-white">
          {l.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a href={SOCIAL.tiktok} target="_blank" rel="noopener" aria-label="TikTok"
         class="rounded-full border border-winter-600 px-3 py-1 text-xs font-semibold text-white transition hover:border-star hover:text-star">
        TikTok
      </a>
      <a href={SOCIAL.twitter} target="_blank" rel="noopener" aria-label="X (Twitter)"
         class="rounded-full border border-winter-600 px-3 py-1 text-xs font-semibold text-white transition hover:border-star hover:text-star">
        X
      </a>
    </div>
  </nav>
</header>

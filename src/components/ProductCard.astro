---
// Card de Produto de Afiliado.
// Uso:
//   <ProductCard
//     title="Action Figure Soldado Invernal"
//     description="Marvel Legends, 15cm, articulado."
//     image="/produtos/figure.jpg"
//     price="R$ 249,90"
//     affiliateUrl="https://www.amazon.com.br/dp/XXXX?tag=SEU-TAG-20"
//     store="Amazon"
//     type="action-figure"
//   />

interface Props {
  title: string;
  description?: string;
  image: string;
  price?: string;
  affiliateUrl: string;
  store?: string;
  type?: 'hq' | 'filme' | 'action-figure' | 'livro' | 'geral';
}

const {
  title,
  description = '',
  image,
  price,
  affiliateUrl,
  store = 'Amazon',
  type = 'geral',
} = Astro.props;

const typeLabels: Record<string, string> = {
  hq: 'HQ',
  filme: 'Filme',
  'action-figure': 'Action Figure',
  livro: 'Livro',
  geral: 'Produto',
};
---

<article
  class="group flex flex-col overflow-hidden rounded-xl border border-winter-600/60 bg-winter-800 transition hover:-translate-y-1 hover:border-star/70 hover:shadow-xl hover:shadow-black/40"
>
  <div class="relative aspect-square overflow-hidden bg-gradient-to-br from-winter-700 to-winter-900">
    {image ? (
      <img
        src={image}
        alt={title}
        loading="lazy"
        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center">
        <span class="font-display text-7xl text-star/25 transition group-hover:text-star/40">★</span>
      </div>
    )}
    <span class="absolute left-3 top-3 rounded-full bg-winter-900/80 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-accent backdrop-blur">
      {typeLabels[type]}
    </span>
  </div>

  <div class="flex flex-1 flex-col p-5">
    <h3 class="font-display text-lg font-semibold leading-snug text-white">{title}</h3>
    {description && <p class="mt-2 flex-1 text-sm text-steel">{description}</p>}

    <div class="mt-4 flex items-center justify-between">
      {price && <span class="font-display text-xl font-bold text-white">{price}</span>}
      <span class="text-xs text-steel/70">{store}</span>
    </div>

    <!-- rel="sponsored nofollow noopener" é a boa prática para links de afiliado -->
    <a
      href={affiliateUrl}
      target="_blank"
      rel="sponsored nofollow noopener"
      class="mt-4 inline-flex items-center justify-center rounded-lg bg-star px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-red-700"
    >
      Comprar na {store} →
    </a>
  </div>
</article>

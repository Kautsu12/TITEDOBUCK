---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  image = '/og-default.jpg',
} = Astro.props;

const pageTitle = title === SITE.title ? title : `${title} · ${SITE.title}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / redes sociais -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fontes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --z-header: 50;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
      }
      /* Títulos com quebra equilibrada e tracking de display dentro do limite legível */
      h1, h2, h3 {
        text-wrap: balance;
        letter-spacing: -0.02em;
      }
      p {
        text-wrap: pretty;
      }
      /* Foco visível e acessível em toda a navegação por teclado */
      :focus-visible {
        outline: 2px solid #c81d25;
        outline-offset: 3px;
        border-radius: 3px;
      }
      ::selection {
        background: #c81d25;
        color: #fff;
      }
      /* Entrada suave do conteúdo, sempre visível por padrão (sem travar o conteúdo) */
      @media (prefers-reduced-motion: no-preference) {
        .reveal {
          animation: reveal 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
        }
      }
      @keyframes reveal {
        from { opacity: 0; transform: translateY(14px); }
        to { opacity: 1; transform: none; }
      }
    </style>
  </head>
  <body class="min-h-screen bg-winter-900 font-body text-steel antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
